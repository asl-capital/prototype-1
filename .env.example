# Required: OpenAI API key for the Aseel AI assistant
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Override the OpenAI base URL (defaults to https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Override the port (defaults to 3001 in dev, uses PORT env var in production)
# PORT=3001
